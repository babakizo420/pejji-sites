---
import Base from '../layouts/Base.astro';
import { WHATSAPP_URL } from '../config';
---

<Base title="Services & Pricing | Pejji" description="No hidden fees. No surprises. Pick your tier, we handle the rest. Starting from ₦60,000.">

  <!-- HEADER -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h1 class="text-4xl sm:text-5xl font-bold">What We Build & What It Costs</h1>
      <p class="mt-6 text-subtle text-lg max-w-2xl mx-auto">No hidden fees. No surprises. Pick your tier, we handle the rest.</p>
    </div>
  </section>

  <!-- TIER CARDS -->
  <section class="pb-16 sm:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 stagger-children">

        <!-- Card Tier -->
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 hover:border-teal/20">
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Card</div>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="text-4xl font-bold">₦60,000</span>
          </div>
          <p class="text-subtle text-sm mt-2">+ ₦10,000/mo hosting & support</p>
          <p class="text-subtle mt-4">48-hour delivery &middot; 1 revision round</p>
          <ul class="mt-6 space-y-3">
            {[
              "Single page digital business card",
              "Mobile responsive design",
              "WhatsApp click-to-chat button",
              "Google Maps integration",
              "Basic SEO setup",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-light">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contact?tier=card" class="mt-8 block text-center px-6 py-3.5 border-2 border-teal text-teal font-semibold rounded-lg hover:bg-teal/10 transition-colors">
            Get Started with Card
          </a>
        </div>

        <!-- Starter -->
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 hover:border-teal/20">
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Starter</div>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="text-4xl font-bold">₦150-200K</span>
          </div>
          <p class="text-subtle text-sm mt-2">+ ₦15,000/mo hosting & support</p>
          <p class="text-subtle mt-4">5-7 day delivery &middot; 2 revision rounds</p>
          <ul class="mt-6 space-y-3">
            {[
              "Multi-section landing page",
              "Contact/inquiry form",
              "Social media integration",
              "Google Analytics setup",
              "Basic SEO optimization",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-light">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contact?tier=starter" class="mt-8 block text-center px-6 py-3.5 border-2 border-teal text-teal font-semibold rounded-lg hover:bg-teal/10 transition-colors">
            Get Started with Starter
          </a>
        </div>

        <!-- Growth -->
        <div class="card-tactile bg-surface border-2 border-teal/50 rounded-2xl p-8 relative hover:shadow-lg hover:shadow-teal/10">
          <div class="absolute -top-3 right-6 bg-orange text-white text-xs font-semibold px-3 py-1 rounded-full">Most Popular</div>
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Growth</div>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="text-4xl font-bold">₦250-400K</span>
          </div>
          <p class="text-subtle text-sm mt-2">+ ₦20,000/mo hosting & support</p>
          <p class="text-subtle mt-4">7-14 day delivery &middot; 3 revision rounds</p>
          <ul class="mt-6 space-y-3">
            {[
              "Multi-page website (up to 5 pages)",
              "Booking/scheduling system",
              "Blog or news section",
              "Advanced SEO optimization",
              "WhatsApp Business integration",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-light">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contact?tier=growth" class="mt-8 block text-center px-6 py-3.5 bg-teal text-dark font-semibold rounded-lg hover:bg-teal/90 transition-colors">
            Get Started with Growth
          </a>
        </div>

        <!-- Pro -->
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 hover:border-teal/20">
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Pro</div>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="text-4xl font-bold">₦500-800K</span>
          </div>
          <p class="text-subtle text-sm mt-2">+ ₦30,000/mo hosting & support</p>
          <p class="text-subtle mt-4">14-21 day delivery &middot; 3 revision rounds</p>
          <ul class="mt-6 space-y-3">
            {[
              "Full ecommerce store",
              "Product catalog with categories",
              "Paystack/Flutterwave payment integration",
              "Inventory management",
              "Customer accounts",
              "Advanced analytics dashboard",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-light">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contact?tier=pro" class="mt-8 block text-center px-6 py-3.5 border-2 border-teal text-teal font-semibold rounded-lg hover:bg-teal/10 transition-colors">
            Get Started with Pro
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ADD-ON SERVICES -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Add-On Services</h2>
        <p class="mt-4 text-subtle text-lg">Enhance your website with extras.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger-children">
        {[
          { name: "WhatsApp Business Setup", price: "₦15,000" },
          { name: "AI Chatbot", price: "₦40-60,000 + ₦10K/mo" },
          { name: "SEO Optimization Package", price: "₦30-50,000" },
          { name: "Blog/Content Setup", price: "₦25,000" },
          { name: "Professional Email Setup", price: "₦20,000" },
          { name: "Social Media Links Page", price: "₦15,000" },
          { name: "Booking/Scheduling System", price: "₦30,000" },
          { name: "Payment Integration", price: "₦35,000" },
          { name: "E-commerce Add-on", price: "₦50-80,000" },
          { name: "Analytics Dashboard", price: "₦20-30,000 + ₦10K/mo" },
          { name: "Branded Print Package", price: "₦15-20,000" },
          { name: "Google Business Profile", price: "₦10-15,000" },
        ].map((addon) => (
          <div class="flex items-center justify-between p-5 bg-surface border border-white/5 rounded-xl hover:border-teal/20 transition-colors">
            <span class="text-light text-sm font-medium">{addon.name}</span>
            <span class="text-teal text-sm font-semibold whitespace-nowrap ml-4">{addon.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Compare Plans</h2>
      </div>
      <div class="overflow-x-auto reveal">
        <table class="w-full min-w-[600px]">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left py-4 pr-4 text-subtle text-sm font-medium">Feature</th>
              <th class="py-4 px-4 text-center text-sm font-semibold">Card</th>
              <th class="py-4 px-4 text-center text-sm font-semibold">Starter</th>
              <th class="py-4 px-4 text-center text-sm font-semibold text-teal">Growth</th>
              <th class="py-4 px-4 text-center text-sm font-semibold">Pro</th>
            </tr>
          </thead>
          <tbody class="text-sm">
            {[
              { feature: "Pages", card: "1", starter: "1 (multi-section)", growth: "Up to 5", pro: "Unlimited" },
              { feature: "Mobile Responsive", card: true, starter: true, growth: true, pro: true },
              { feature: "SEO Setup", card: "Basic", starter: "Basic", growth: "Advanced", pro: "Advanced" },
              { feature: "Contact Form", card: false, starter: true, growth: true, pro: true },
              { feature: "WhatsApp Integration", card: "Button", starter: "Button", growth: "Business", pro: "Business" },
              { feature: "Analytics", card: false, starter: true, growth: true, pro: "Advanced" },
              { feature: "Blog", card: false, starter: false, growth: true, pro: true },
              { feature: "Booking System", card: false, starter: false, growth: true, pro: true },
              { feature: "E-commerce", card: false, starter: false, growth: false, pro: true },
              { feature: "Payment Integration", card: false, starter: false, growth: false, pro: true },
              { feature: "Customer Accounts", card: false, starter: false, growth: false, pro: true },
              { feature: "Revision Rounds", card: "1", starter: "2", growth: "3", pro: "3" },
              { feature: "Delivery Time", card: "48hrs", starter: "5-7 days", growth: "7-14 days", pro: "14-21 days" },
              { feature: "Security Audit", card: true, starter: true, growth: true, pro: true },
            ].map((row) => (
              <tr class="border-b border-white/5">
                <td class="py-3.5 pr-4 text-light">{row.feature}</td>
                {[row.card, row.starter, row.growth, row.pro].map((val) => (
                  <td class="py-3.5 px-4 text-center">
                    {val === true ? (
                      <svg class="w-5 h-5 text-teal mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    ) : val === false ? (
                      <span class="text-subtle">-</span>
                    ) : (
                      <span class="text-subtle">{val}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-4 reveal">
        {[
          { q: "Can I upgrade my tier later?", a: "Yes! You can upgrade at any time. We'll assess what you have and build on top of it. You only pay the difference plus any new features." },
          { q: "What do I need to provide?", a: "Your logo (if you have one), photos of your business/products, text content you'd like on the site, and your social media links. We'll send you a simple checklist via WhatsApp." },
          { q: "How do I pay?", a: "We accept bank transfer and Paystack payments. 50% deposit to start, remaining 50% before launch." },
          { q: "What if I need changes after launch?", a: "Minor changes are covered under your monthly hosting plan. For major updates or new features, we'll provide a separate quote." },
          { q: "Do you design logos?", a: "Logo design is available as an add-on service. We can also recommend trusted designers in our network." },
          { q: "What happens if I stop paying hosting?", a: "Your site stays live for 30 days after a missed payment. After that, it goes offline but your files are kept safe for 90 days so you can reactivate anytime." },
          { q: "Do I own my website?", a: "Absolutely. You own all the content and code. If you ever want to move to a different host, we'll help you with the transition." },
          { q: "Can you work with my existing domain?", a: "Yes. If you already have a domain, we'll connect it to your new site. If you don't have one, we'll help you pick and register one." },
        ].map((faq) => (
          <details class="group bg-surface border border-white/5 rounded-xl">
            <summary class="flex items-center justify-between cursor-pointer p-6 text-light font-medium">
              {faq.q}
              <svg class="w-5 h-5 text-subtle flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-6 text-subtle text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl sm:text-4xl font-bold">Ready to get started?</h2>
      <p class="mt-4 text-subtle text-lg">Pick a tier and let's build your website.</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-green-500 text-white font-semibold rounded-lg hover:bg-green-600 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 transition-colors">
          Get Started
        </a>
      </div>
    </div>
  </section>

</Base>
