---
import Base from '../layouts/Base.astro';
---

<Base title="How It Works — Pejji" description="From first message to launch day. Our simple 5-step process gets your business online fast.">

  <!-- HEADER -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold">From First Message to Launch Day</h1>
      <p class="mt-6 text-subtle text-lg max-w-2xl mx-auto">Our simple 5-step process gets your business online fast.</p>
    </div>
  </section>

  <!-- DETAILED STEPS -->
  <section class="pb-16 sm:pb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">

        <!-- Step 1 -->
        <div class="relative bg-surface border border-white/5 rounded-2xl p-8 sm:p-10">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">01</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">Tell Us What You Need</h3>
              <ul class="mt-4 space-y-3">
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  DM us on Instagram or WhatsApp, or fill out our quick form
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  No long phone calls needed for Card and Starter tiers
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  We'll recommend the right tier for your business
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative bg-surface border border-white/5 rounded-2xl p-8 sm:p-10">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">02</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">Content Collection</h3>
              <ul class="mt-4 space-y-3">
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  We send you a simple checklist: logo, photos, text, social links
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  You send via WhatsApp — no complicated uploads
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Our team organizes everything
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative bg-surface border border-white/5 rounded-2xl p-8 sm:p-10">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">03</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">We Build Your Site</h3>
              <ul class="mt-4 space-y-3">
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Professional development (not templates)
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Mobile-first design
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Every site passes our security audit before you see it
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="relative bg-surface border border-white/5 rounded-2xl p-8 sm:p-10">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">04</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">You Review & We Refine</h3>
              <ul class="mt-4 space-y-3">
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  We share a preview link
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  You request changes (1-3 rounds depending on tier)
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  We refine until you're happy
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="relative bg-surface border border-white/5 rounded-2xl p-8 sm:p-10">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">05</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">Launch Day</h3>
              <ul class="mt-4 space-y-3">
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Domain connected, SSL active
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Google Analytics installed
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  You get a handover guide
                </li>
                <li class="flex items-start gap-3 text-subtle text-sm">
                  <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Ongoing hosting + support begins
                </li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold">Timeline Expectations</h2>
        <p class="mt-4 text-subtle text-lg">How fast can we get you online?</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        {[
          { tier: "Card", time: "48 hours", color: "border-teal/30" },
          { tier: "Starter", time: "5-7 days", color: "border-teal/30" },
          { tier: "Growth", time: "7-14 days", color: "border-teal/30" },
          { tier: "Pro", time: "14-21 days", color: "border-teal/30" },
        ].map((item) => (
          <div class={`bg-surface border ${item.color} rounded-2xl p-6 sm:p-8 text-center`}>
            <div class="text-teal text-sm font-semibold uppercase tracking-wider">{item.tier}</div>
            <div class="mt-3 text-2xl sm:text-3xl font-bold">{item.time}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold">Ready to start?</h2>
      <p class="mt-4 text-subtle text-lg">It takes 2 minutes.</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/2348000000000?text=Hi%20Pejji!%20I'm%20interested%20in%20getting%20a%20website%20for%20my%20business." target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-green-500 text-white font-semibold rounded-lg hover:bg-green-600 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 transition-colors">
          Get Started
        </a>
      </div>
    </div>
  </section>

</Base>
