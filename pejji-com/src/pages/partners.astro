---
import Base from '../layouts/Base.astro';
import { WHATSAPP_URL } from '../config';
---

<Base title="Pejji Partners | Earn Cash For Every Referral" description="Know someone who needs a website? Refer them to Pejji. When they sign up, you get paid. No business needed — just connections.">

  <!-- HERO -->
  <section class="relative overflow-hidden py-20 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-br from-teal/10 via-dark to-dark"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-teal/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight reveal">
        Earn Cash For Every Business <span class="text-teal">You Send Our Way</span>
      </h1>
      <p class="reveal mt-6 text-lg sm:text-xl text-subtle max-w-2xl mx-auto leading-relaxed" style="transition-delay: 100ms;">
        Know someone who needs a website? Refer them to Pejji. When they sign up, you get paid. No business needed — just connections.
      </p>
      <div class="reveal mt-10" style="transition-delay: 200ms;">
        <a href="#signup" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 hover:shadow-lg hover:shadow-orange/20 transition-all duration-300">
          Become a Partner
        </a>
      </div>
    </div>
  </section>

  <!-- COMMISSION TIERS -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">What You Earn</h2>
        <p class="mt-4 text-subtle text-lg">Per successful referral. No cap.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
        {[
          { tier: "Card", client: "₦60K", earn: "₦3,000" },
          { tier: "Starter", client: "₦150-200K", earn: "₦5,000" },
          { tier: "Growth", client: "₦250-400K", earn: "₦10,000" },
          { tier: "Pro", client: "₦500-800K", earn: "₦15,000" },
        ].map((item) => (
          <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-6 sm:p-8 text-center hover:border-teal/30">
            <div class="text-teal text-sm font-semibold uppercase tracking-wider">{item.tier} Client</div>
            <div class="mt-4">
              <span class="text-sm text-subtle">Client pays {item.client}</span>
            </div>
            <div class="mt-4 py-3 bg-teal/10 rounded-xl">
              <span class="text-3xl font-bold text-teal">{item.earn}</span>
            </div>
            <p class="mt-3 text-subtle text-sm">You earn per referral</p>
          </div>
        ))}
      </div>
      <p class="text-center mt-10 text-subtle text-lg reveal">No limit. Refer 10 clients, earn up to <span class="text-teal font-semibold">₦150,000</span>.</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">How It Works</h2>
        <p class="mt-4 text-subtle text-lg">3 simple steps. No apps. No tracking codes.</p>
      </div>
      <div class="space-y-8 stagger-children">
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 sm:p-10 hover:border-teal/20">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">01</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">Sign Up Below</h3>
              <p class="mt-2 text-subtle leading-relaxed">Fill out the quick form and we'll send you your personalized Pejji Partner image with YOUR name on it.</p>
            </div>
          </div>
        </div>
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 sm:p-10 hover:border-teal/20">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">02</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">Share With Your Network</h3>
              <p class="mt-2 text-subtle leading-relaxed">Post your partner image on WhatsApp status, send to group chats, share on Instagram. When someone needs a website, they mention your name.</p>
            </div>
          </div>
        </div>
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 sm:p-10 hover:border-teal/20">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-14 h-14 bg-teal/10 rounded-2xl flex items-center justify-center">
              <span class="text-teal text-xl font-bold">03</span>
            </div>
            <div>
              <h3 class="text-xl font-bold">Get Paid</h3>
              <p class="mt-2 text-subtle leading-relaxed">When your referral pays their deposit, we send your commission via bank transfer within 7 days.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">What You Get</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto stagger-children">
        {[
          { icon: "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z", text: "Your own branded Pejji Partner image with your name on it" },
          { icon: "M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z", text: "Ready to share on WhatsApp status and group chats" },
          { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", text: "No tracking codes or apps needed — your referral just mentions your name" },
          { icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z", text: "Paid directly to your bank account" },
        ].map((item) => (
          <div class="card-tactile flex gap-4 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
            <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
            </div>
            <p class="text-light text-sm leading-relaxed pt-1">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SIGN-UP FORM -->
  <section id="signup" class="py-16 sm:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Become a Pejji Partner</h2>
        <p class="mt-4 text-subtle text-lg">Fill this out and we'll send your personalized partner image within 24 hours.</p>
      </div>
      <form id="partner-form" class="reveal bg-surface border border-white/5 rounded-2xl p-8 sm:p-10 space-y-6" style="transition-delay: 100ms;">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="full-name" class="block text-sm font-medium text-light mb-2">Full Name <span class="text-orange">*</span></label>
            <input type="text" id="full-name" name="full_name" required class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. Folake Adeyemi" />
          </div>
          <div>
            <label for="whatsapp" class="block text-sm font-medium text-light mb-2">WhatsApp Number <span class="text-orange">*</span></label>
            <input type="tel" id="whatsapp" name="whatsapp" required class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. 08012345678" />
          </div>
        </div>

        <div>
          <label for="instagram" class="block text-sm font-medium text-light mb-2">Instagram Handle <span class="text-subtle font-normal">(optional)</span></label>
          <input type="text" id="instagram" name="instagram" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. @yourhandle" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="bank-name" class="block text-sm font-medium text-light mb-2">Bank Name <span class="text-orange">*</span></label>
            <input type="text" id="bank-name" name="bank_name" required class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. GTBank" />
          </div>
          <div>
            <label for="account-number" class="block text-sm font-medium text-light mb-2">Account Number <span class="text-orange">*</span></label>
            <input type="text" id="account-number" name="account_number" required class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. 0123456789" />
          </div>
        </div>

        <div>
          <label for="partner-tag" class="block text-sm font-medium text-light mb-2">Choose your partner tag <span class="text-orange">*</span></label>
          <input type="text" id="partner-tag" name="partner_tag" required class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. Chinedu-LK, Amina-ABJ, Tunde-IKJ" />
          <p class="mt-1.5 text-subtle text-xs">This goes on your personalized partner image. Use your name + area. Example: Chinedu-LK, Amina-ABJ, Tunde-IKJ</p>
        </div>

        <div>
          <label for="share-plan" class="block text-sm font-medium text-light mb-2">How do you plan to share Pejji? <span class="text-subtle font-normal">(optional)</span></label>
          <textarea id="share-plan" name="share_plan" rows="3" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors resize-none" placeholder="e.g. WhatsApp groups, Instagram stories, word of mouth..."></textarea>
        </div>

        <button type="submit" class="w-full px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 transition-colors text-center">
          Become a Partner
        </button>
      </form>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Partner FAQ</h2>
      </div>
      <div class="space-y-4 reveal">
        {[
          { q: "Do I need to own a business?", a: "No. Anyone with a phone and contacts can be a partner." },
          { q: "How does Pejji know someone came from me?", a: "Your referral mentions your name when they contact us. Simple." },
          { q: "When do I get paid?", a: "Within 7 days of your referral paying their deposit." },
          { q: "Is there a limit?", a: "No limit. The more you refer, the more you earn." },
          { q: "What if my referral picks a higher tier later?", a: "You earn the commission for whatever tier they end up paying for." },
        ].map((faq) => (
          <details class="group bg-surface border border-white/5 rounded-xl">
            <summary class="flex items-center justify-between cursor-pointer p-6 text-light font-medium">
              {faq.q}
              <svg class="w-5 h-5 text-subtle flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-6 text-subtle text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl sm:text-4xl font-bold">Start earning today.</h2>
      <p class="mt-4 text-subtle text-lg">It takes 60 seconds to sign up.</p>
      <div class="mt-10">
        <a href="#signup" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 hover:shadow-lg hover:shadow-orange/20 transition-all duration-300">
          Become a Partner
        </a>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('partner-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(form as HTMLFormElement);
      const data: Record<string, string> = {};
      formData.forEach((value, key) => { data[key] = value.toString(); });

      const msg = `Hi Pejji! I want to become a Pejji Partner.\n\nName: ${data.full_name}\nWhatsApp: ${data.whatsapp}\nPartner Tag: ${data.partner_tag}\nInstagram: ${data.instagram || 'Not provided'}\nBank: ${data.bank_name}\nAccount: ${data.account_number}\nShare Plan: ${data.share_plan || 'Not specified'}`;
      const waUrl = `https://wa.me/${document.body.dataset.waNumber}?text=${encodeURIComponent(msg)}`;

      // Show success state
      const btn = (form as HTMLFormElement).querySelector('button[type="submit"]');
      if (btn) {
        btn.textContent = 'Redirecting to WhatsApp...';
        btn.setAttribute('disabled', 'true');
      }

      window.open(waUrl, '_blank');

      setTimeout(() => {
        if (btn) {
          btn.textContent = 'Welcome to Pejji Partners!';
          (btn as HTMLElement).classList.remove('bg-orange');
          (btn as HTMLElement).classList.add('bg-teal');
        }
        // Show success message
        const successMsg = document.createElement('p');
        successMsg.className = 'text-teal text-sm mt-4 text-center';
        successMsg.textContent = "Welcome to Pejji Partners! We'll send your personalized partner image with your tag to your WhatsApp within 24 hours.";
        form?.appendChild(successMsg);
      }, 2000);
    });
  </script>

</Base>
