---
import Base from '../layouts/Base.astro';
import { WHATSAPP_URL } from '../config';
---

<Base title="Get Started | Pejji" description="Fill out the form below or message us directly on WhatsApp. We typically respond within 2 hours.">

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- HEADER -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold reveal">Let's Build Your Website</h1>
      <p class="mt-6 text-subtle text-lg max-w-2xl mx-auto reveal" style="transition-delay: 100ms;">Fill out the form below or message us directly on WhatsApp.</p>
    </div>
  </section>

  <!-- FORM + CONTACT -->
  <section class="pb-16 sm:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">

        <!-- Form -->
        <div class="lg:col-span-3">
          <form id="inquiry-form" action="https://api.web3forms.com/submit" method="POST" class="reveal-left bg-surface border border-white/5 rounded-2xl p-8 sm:p-10 space-y-6">
            <input type="hidden" name="access_key" value="098e89e5-22db-4cde-92b4-c1ebd8125940">
            <input type="hidden" name="subject" value="New Pejji Lead from Website">
            <input type="hidden" name="from_name" value="Pejji Website Contact Form">
            <input type="hidden" name="redirect" value="https://pejji.com/contact?success=true">
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="business-name" class="block text-sm font-medium text-light mb-2">Business Name <span class="text-orange">*</span></label>
                <input type="text" id="business-name" name="business_name" required minlength="2" maxlength="100" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. Iya Basira Kitchen" />
              </div>
              <div>
                <label for="your-name" class="block text-sm font-medium text-light mb-2">Your Name <span class="text-orange">*</span></label>
                <input type="text" id="your-name" name="your_name" required minlength="2" maxlength="80" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. Folake Adeyemi" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-sm font-medium text-light mb-2">Phone / WhatsApp <span class="text-orange">*</span></label>
                <input type="tel" id="phone" name="phone" required pattern="^(\+?234|0)[0-9]{9,10}$" maxlength="15" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. 08012345678" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-light mb-2">Email <span class="text-subtle font-normal">(optional)</span></label>
                <input type="email" id="email" name="email" maxlength="120" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors" placeholder="e.g. folake@example.com" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="industry" class="block text-sm font-medium text-light mb-2">Industry</label>
                <select id="industry" name="industry" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors">
                  <option value="">Select your industry</option>
                  <option value="restaurant">Restaurant / Food</option>
                  <option value="retail">Retail / E-commerce</option>
                  <option value="services">Services</option>
                  <option value="beauty">Health / Beauty</option>
                  <option value="education">Education</option>
                  <option value="realestate">Real Estate</option>
                  <option value="tech">Tech / Startup</option>
                  <option value="logistics">Logistics</option>
                  <option value="fashion">Fashion</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="tier" class="block text-sm font-medium text-light mb-2">What tier interests you?</label>
                <select id="tier" name="tier" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors">
                  <option value="">Select a tier</option>
                  <option value="card">Card (₦60K)</option>
                  <option value="starter">Starter (₦150K)</option>
                  <option value="growth">Growth (₦300K)</option>
                  <option value="pro">Pro (₦800K+)</option>
                  <option value="unsure">Not sure yet</option>
                </select>
              </div>
            </div>

            <div>
              <label for="about" class="block text-sm font-medium text-light mb-2">Tell us about your business <span class="text-subtle font-normal">(optional)</span></label>
              <textarea id="about" name="about" rows="4" maxlength="1000" class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-light text-sm placeholder-subtle focus:outline-none focus:border-teal/50 focus:ring-1 focus:ring-teal/50 transition-colors resize-none" placeholder="What does your business do? What do you want from your website?"></textarea>
            </div>

            <div>
              <label class="block text-sm font-medium text-light mb-3">Do you have a logo?</label>
              <div class="flex gap-6">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="has_logo" value="yes" class="w-4 h-4 text-teal bg-dark border-white/20 focus:ring-teal/50" />
                  <span class="text-sm text-light">Yes</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="has_logo" value="no" class="w-4 h-4 text-teal bg-dark border-white/20 focus:ring-teal/50" />
                  <span class="text-sm text-light">No</span>
                </label>
              </div>
            </div>

            <div class="cf-turnstile" data-sitekey="0x4AAAAAAC0oimix5MWShwK0" data-theme="dark"></div>

            <button type="submit" class="w-full px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 transition-colors text-center">
              Get Started
            </button>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Direct Contact -->
          <div class="reveal-right bg-surface border border-white/5 rounded-2xl p-8">
            <h3 class="font-semibold text-lg mb-6">Or reach us directly</h3>
            <div class="space-y-5">
              <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="flex items-center gap-4 p-4 bg-green-500/10 border border-green-500/20 rounded-xl hover:bg-green-500/20 transition-colors">
                <div class="w-12 h-12 bg-green-500 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </div>
                <div>
                  <p class="font-medium text-light">WhatsApp</p>
                  <p class="text-green-400 text-sm">Chat with us now</p>
                </div>
              </a>
              <a href="mailto:hello@pejji.com" class="flex items-center gap-4 p-4 bg-surface border border-white/10 rounded-xl hover:border-teal/20 transition-colors">
                <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-medium text-light">Email</p>
                  <p class="text-subtle text-sm">hello@pejji.com</p>
                </div>
              </a>
              <a href="https://instagram.com/pejji.ng" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 bg-surface border border-white/10 rounded-xl hover:border-teal/20 transition-colors">
                <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-teal" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </div>
                <div>
                  <p class="font-medium text-light">Instagram</p>
                  <p class="text-subtle text-sm">@pejji.ng</p>
                </div>
              </a>
            </div>
            <p class="mt-6 text-subtle text-sm">We typically respond within <span class="text-teal font-medium">2 hours</span>.</p>
          </div>

          <!-- What Happens Next -->
          <div class="reveal-right bg-surface border border-white/5 rounded-2xl p-8" style="transition-delay: 150ms;">
            <h3 class="font-semibold text-lg mb-5">What happens next?</h3>
            <ol class="space-y-4">
              {[
                "We review your request (same day)",
                "We recommend the right tier for you",
                "You approve + pay deposit",
                "We start building",
              ].map((step, i) => (
                <li class="flex items-start gap-3">
                  <span class="flex-shrink-0 w-7 h-7 bg-teal/10 rounded-full flex items-center justify-center text-teal text-xs font-bold">{i + 1}</span>
                  <span class="text-subtle text-sm pt-1">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    // Pre-select tier from URL params
    const params = new URLSearchParams(window.location.search);
    const tierParam = params.get('tier');
    if (tierParam) {
      const tierSelect = document.getElementById('tier') as HTMLSelectElement;
      if (tierSelect) {
        tierSelect.value = tierParam;
      }
    }

    // Form submission via Web3Forms with Turnstile validation
    const form = document.getElementById('inquiry-form') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous errors
      form.querySelectorAll('.field-error').forEach(el => el.remove());
      form.querySelectorAll('.border-red-500').forEach(el => el.classList.remove('border-red-500'));

      let hasError = false;

      // Validate business name
      const bizName = form.querySelector('#business-name') as HTMLInputElement;
      if (bizName && bizName.value.trim().length < 2) {
        bizName.classList.add('border-red-500');
        bizName.insertAdjacentHTML('afterend', '<p class="field-error text-red-400 text-xs mt-1">Enter your business name</p>');
        if (!hasError) { bizName.focus(); hasError = true; }
      }

      // Validate your name
      const yourName = form.querySelector('#your-name') as HTMLInputElement;
      if (yourName && yourName.value.trim().length < 2) {
        yourName.classList.add('border-red-500');
        yourName.insertAdjacentHTML('afterend', '<p class="field-error text-red-400 text-xs mt-1">Enter your name</p>');
        if (!hasError) { yourName.focus(); hasError = true; }
      }

      // Validate phone
      const phone = form.querySelector('#phone') as HTMLInputElement;
      const phoneVal = phone?.value.trim();
      const phonePattern = /^(\+?234|0)[0-9]{9,10}$/;
      if (!phoneVal || !phonePattern.test(phoneVal)) {
        phone.classList.add('border-red-500');
        phone.insertAdjacentHTML('afterend', '<p class="field-error text-red-400 text-xs mt-1">Enter a valid Nigerian phone number (e.g. 08012345678)</p>');
        if (!hasError) { phone.focus(); hasError = true; }
      }

      // Validate email format if provided
      const email = form.querySelector('#email') as HTMLInputElement;
      const emailVal = email?.value.trim();
      if (emailVal && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
        email.classList.add('border-red-500');
        email.insertAdjacentHTML('afterend', '<p class="field-error text-red-400 text-xs mt-1">Enter a valid email address</p>');
        if (!hasError) { email.focus(); hasError = true; }
      }

      if (hasError) return;

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = btn?.textContent || 'Get Started';

      // Check Turnstile completion
      const turnstileResponse = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
      if (!turnstileResponse || !turnstileResponse.value) {
        if (btn) {
          btn.textContent = 'Please complete the verification';
          btn.style.background = '#ef4444';
          setTimeout(() => {
            btn.textContent = originalText;
            btn.style.background = '';
          }, 2500);
        }
        return;
      }

      if (btn) {
        btn.textContent = 'Sending...';
        btn.setAttribute('disabled', 'true');
      }

      try {
        const formData = new FormData(form);
        // Remove Turnstile token - Web3Forms doesn't need it
        formData.delete('cf-turnstile-response');
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const result = await response.json();

        if (result.success) {
          // Send Telegram notification with lead details
          try {
            const leadData = Object.fromEntries(formData.entries());
            const msg = `NEW PEJJI LEAD\n\nBusiness: ${leadData.business_name || '-'}\nName: ${leadData.your_name || '-'}\nPhone: ${leadData.phone || '-'}\nEmail: ${leadData.email || '-'}\nIndustry: ${leadData.industry || '-'}\nTier: ${leadData.tier || '-'}\nHas Logo: ${leadData.has_logo || '-'}\nAbout: ${leadData.about || '-'}\n\nSource: pejji.com/contact`;
            fetch('https://api.telegram.org/bot8616559738:AAGkj_079rqvx-qiN6nkQG-8IvkcBEeLYEk/sendMessage', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ chat_id: '5413679846', text: msg })
            }).catch(() => {});

            // Log lead to Notion via Cloudflare Worker
            fetch('https://pejji-lead-logger.babakizo542.workers.dev/log-lead', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                business_name: leadData.business_name || '',
                your_name: leadData.your_name || '',
                phone: leadData.phone || '',
                email: leadData.email || '',
                industry: leadData.industry || '',
                tier: leadData.tier || '',
                about: leadData.about || '',
                has_logo: leadData.has_logo || '',
              })
            }).catch(() => {});
          } catch {}

          if (btn) {
            btn.textContent = 'Sent! We\'ll be in touch.';
            btn.classList.remove('bg-orange');
            btn.classList.add('bg-green-500');
          }
          form.reset();
        } else {
          throw new Error(result.message || 'Submission failed');
        }
      } catch {
        if (btn) {
          btn.textContent = 'Something went wrong. Try again.';
          btn.removeAttribute('disabled');
          setTimeout(() => { btn.textContent = originalText; }, 3000);
        }
      }
    });

    // Show success message if redirected back with ?success=true
    const successParam = new URLSearchParams(window.location.search).get('success');
    if (successParam === 'true') {
      const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (btn) {
        btn.textContent = 'Sent! We\'ll be in touch.';
        btn.classList.remove('bg-orange');
        btn.classList.add('bg-green-500');
        btn.setAttribute('disabled', 'true');
      }
    }
  </script>

</Base>
