---
import Base from '../layouts/Base.astro';
import { WHATSAPP_URL } from '../config';
---

<Base title="Page Not Found | Pejji" description="The page you're looking for doesn't exist.">

  <section class="py-24 sm:py-32">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-7xl sm:text-8xl font-bold text-teal mb-4 reveal">404</p>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 reveal" style="transition-delay: 100ms;">Page not found</h1>
      <p class="text-subtle text-lg mb-10 reveal" style="transition-delay: 200ms;">Let's get you back on track.</p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal" style="transition-delay: 300ms;">
        <a href="/" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-teal text-dark font-semibold rounded-lg hover:bg-teal/90 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
          Homepage
        </a>
        <a href="/services" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-surface border border-white/10 text-light font-semibold rounded-lg hover:border-white/20 transition-colors">
          Services
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-surface border border-white/10 text-light font-semibold rounded-lg hover:border-white/20 transition-colors">
          Contact
        </a>
      </div>

      <div class="mt-8 reveal" style="transition-delay: 400ms;">
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-green-500 hover:text-green-400 transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat with us on WhatsApp
        </a>
      </div>
    </div>
  </section>

</Base>
