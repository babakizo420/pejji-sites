---
import Base from '../layouts/Base.astro';

const projects = [
  { name: "Iya Basira Kitchen", industry: "Restaurant", tier: "Growth", desc: "Full restaurant site with online ordering, menu display, and reservation system. Increased orders by 40%.", gradient: "from-teal/20 to-surface" },
  { name: "Ade & Co. Fashion", industry: "Fashion", tier: "Pro", desc: "Complete ecommerce store with Paystack payments, product catalog, and inventory management.", gradient: "from-orange/20 to-surface" },
  { name: "SwiftDrop Logistics", industry: "Logistics", tier: "Starter", desc: "Professional landing page with booking form, real-time tracking link, and WhatsApp integration.", gradient: "from-green-500/20 to-surface" },
  { name: "GlowUp Beauty Lounge", industry: "Beauty", tier: "Growth", desc: "Multi-page site with booking system, service catalog, and before/after gallery.", gradient: "from-pink-500/20 to-surface" },
  { name: "TechBridge Solutions", industry: "Tech", tier: "Starter", desc: "Sleek landing page showcasing IT consulting services with inquiry form and case studies.", gradient: "from-blue-500/20 to-surface" },
  { name: "Mama Nkechi Catering", industry: "Services", tier: "Card", desc: "Digital business card with menu highlights, WhatsApp ordering, and Google Maps location.", gradient: "from-yellow-500/20 to-surface" },
];
---

<Base title="Our Work | Pejji" description="Real sites for real businesses. Built fast, built secure. See our portfolio of Nigerian business websites.">

  <!-- HEADER -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold">Our Work</h1>
      <p class="mt-6 text-subtle text-lg max-w-2xl mx-auto">Real sites for real businesses. Built fast, built secure.</p>
    </div>
  </section>

  <!-- FILTER + GRID -->
  <section class="pb-16 sm:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filters -->
      <div class="flex flex-wrap gap-3 mb-10 justify-center">
        {["All", "Card", "Starter", "Growth", "Pro"].map((filter) => (
          <button
            data-filter={filter.toLowerCase()}
            class:list={[
              "px-5 py-2 rounded-full text-sm font-medium transition-colors filter-btn",
              filter === "All" ? "bg-teal text-dark" : "bg-surface border border-white/10 text-subtle hover:text-light hover:border-teal/30"
            ]}
          >
            {filter}
          </button>
        ))}
      </div>

      <!-- Project Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="project-grid">
        {projects.map((project) => (
          <div class="project-card bg-surface border border-white/5 rounded-2xl overflow-hidden hover:border-teal/30 transition-all" data-tier={project.tier.toLowerCase()}>
            <div class={`aspect-video bg-gradient-to-br ${project.gradient} flex items-center justify-center`}>
              <div class="text-center">
                <div class="w-16 h-16 mx-auto bg-white/10 rounded-xl flex items-center justify-center mb-3">
                  <svg class="w-8 h-8 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <span class="text-white/30 text-xs">Live Preview Coming Soon</span>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs bg-teal/10 text-teal px-2.5 py-1 rounded-full">{project.industry}</span>
                <span class="text-xs bg-white/5 text-subtle px-2.5 py-1 rounded-full">{project.tier}</span>
              </div>
              <h3 class="font-semibold text-lg">{project.name}</h3>
              <p class="text-subtle text-sm mt-2 leading-relaxed">{project.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold">Want results like these?</h2>
      <p class="mt-4 text-subtle text-lg">Let's build yours.</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/2348000000000?text=Hi%20Pejji!%20I'm%20interested%20in%20getting%20a%20website%20for%20my%20business." target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-green-500 text-white font-semibold rounded-lg hover:bg-green-600 transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 transition-colors">
          Get Started
        </a>
      </div>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.project-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        buttons.forEach(b => {
          b.classList.remove('bg-teal', 'text-dark');
          b.classList.add('bg-surface', 'border', 'border-white/10', 'text-subtle');
        });
        btn.classList.add('bg-teal', 'text-dark');
        btn.classList.remove('bg-surface', 'border', 'border-white/10', 'text-subtle');

        cards.forEach(card => {
          const tier = card.getAttribute('data-tier');
          if (filter === 'all' || tier === filter) {
            (card as HTMLElement).style.display = '';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>

</Base>
