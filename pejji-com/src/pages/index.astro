---
import Base from '../layouts/Base.astro';
---

<Base title="Pejji | Your Business Deserves a Website That Works" description="We build fast, secure, beautiful websites for Nigerian businesses. Starting from ₦60,000.">

  <!-- HERO -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-br from-teal/10 via-dark to-dark"></div>
    <div class="absolute inset-0 hero-shimmer"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-teal/5 rounded-full blur-3xl hero-glow"></div>
    <!-- Floating particles -->
    <div class="particle w-2 h-2 bg-teal/30 top-[20%] left-[15%]" style="animation: float1 12s ease-in-out infinite;"></div>
    <div class="particle w-3 h-3 bg-orange/20 top-[40%] right-[20%]" style="animation: float2 15s ease-in-out infinite; animation-delay: -3s;"></div>
    <div class="particle w-1.5 h-1.5 bg-teal/40 top-[60%] left-[70%]" style="animation: float1 10s ease-in-out infinite; animation-delay: -5s;"></div>
    <div class="particle w-2.5 h-2.5 bg-teal/20 top-[30%] left-[50%]" style="animation: float2 18s ease-in-out infinite; animation-delay: -8s;"></div>
    <div class="particle w-1 h-1 bg-orange/30 top-[70%] left-[30%]" style="animation: float1 14s ease-in-out infinite; animation-delay: -2s;"></div>
    <div class="particle w-2 h-2 bg-teal/25 top-[15%] right-[35%]" style="animation: float2 11s ease-in-out infinite; animation-delay: -6s;"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
      <div class="max-w-3xl">
        <h1 class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
          Your Business Deserves a Website That <span class="text-teal">Works</span>
        </h1>
        <p class="reveal mt-6 text-lg sm:text-xl text-subtle max-w-2xl leading-relaxed" style="transition-delay: 100ms;">
          We build fast, secure, beautiful websites for Nigerian businesses. Starting from ₦60,000.
        </p>
        <div class="reveal mt-10 flex flex-col sm:flex-row gap-4" style="transition-delay: 200ms;">
          <a href="#portfolio" class="inline-flex items-center justify-center px-8 py-4 border-2 border-teal text-teal font-semibold rounded-lg hover:bg-teal/10 hover:shadow-lg hover:shadow-teal/10 transition-all duration-300 text-center">
            See Our Work
          </a>
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 hover:shadow-lg hover:shadow-orange/20 transition-all duration-300 text-center">
            Get Started
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM STATEMENT -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-xl sm:text-2xl lg:text-3xl font-medium leading-relaxed text-light">
          95% of Nigerian SMEs don't have a website. <span class="text-teal">Your competitors already do.</span>
        </p>
        <p class="mt-6 text-subtle text-lg leading-relaxed">
          Every day without one, you're losing customers to businesses that show up online.
        </p>
      </div>
    </div>
  </section>

  <!-- TIER PREVIEW CARDS -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Pick Your Tier</h2>
        <p class="mt-4 text-subtle text-lg">Transparent pricing. No hidden fees.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
        <!-- Card Tier -->
        <div class="card-tactile card-glow bg-surface border border-white/5 rounded-2xl p-6 sm:p-8 hover:border-teal/30 group">
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Card</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦60K</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Digital business card. Get online in 48 hours.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦10K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-teal text-sm font-medium group-hover:gap-2 transition-all">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
        <!-- Starter -->
        <div class="card-tactile card-glow bg-surface border border-white/5 rounded-2xl p-6 sm:p-8 hover:border-teal/30 group">
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Starter</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦150-200K</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Professional landing page that converts.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦15K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-teal text-sm font-medium group-hover:gap-2 transition-all">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
        <!-- Growth -->
        <div class="card-tactile card-glow bg-surface border border-white/5 rounded-2xl p-6 sm:p-8 hover:border-teal/30 group relative">
          <div class="absolute -top-3 right-6 bg-orange text-white text-xs font-semibold px-3 py-1 rounded-full">Popular</div>
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Growth</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦250-400K</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Booking, services, and customer management.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦20K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-teal text-sm font-medium group-hover:gap-2 transition-all">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
        <!-- Pro -->
        <div class="card-tactile card-glow bg-surface border border-white/5 rounded-2xl p-6 sm:p-8 hover:border-teal/30 group">
          <div class="text-teal text-sm font-semibold uppercase tracking-wider">Pro</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦500-800K</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Full ecommerce store with payments.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦30K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-teal text-sm font-medium group-hover:gap-2 transition-all">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO PREVIEW -->
  <section id="portfolio" class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Our Work</h2>
        <p class="mt-4 text-subtle text-lg">Real sites for real businesses.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl overflow-hidden group hover:border-teal/30">
          <div class="aspect-video bg-gradient-to-br from-teal/20 to-surface flex items-center justify-center overflow-hidden">
            <span class="text-subtle text-sm group-hover:scale-110 transition-transform duration-500">Screenshot Preview</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs bg-teal/10 text-teal px-2.5 py-1 rounded-full">Restaurant</span>
              <span class="text-xs bg-white/5 text-subtle px-2.5 py-1 rounded-full">Growth</span>
            </div>
            <h3 class="font-semibold text-lg">Iya Basira Kitchen</h3>
            <p class="text-subtle text-sm mt-2">Full restaurant site with online ordering and reservation system.</p>
          </div>
        </div>
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl overflow-hidden group hover:border-teal/30">
          <div class="aspect-video bg-gradient-to-br from-orange/20 to-surface flex items-center justify-center overflow-hidden">
            <span class="text-subtle text-sm group-hover:scale-110 transition-transform duration-500">Screenshot Preview</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs bg-teal/10 text-teal px-2.5 py-1 rounded-full">Fashion</span>
              <span class="text-xs bg-white/5 text-subtle px-2.5 py-1 rounded-full">Pro</span>
            </div>
            <h3 class="font-semibold text-lg">Ade & Co. Fashion</h3>
            <p class="text-subtle text-sm mt-2">Full ecommerce store with Paystack payments and inventory management.</p>
          </div>
        </div>
        <div class="card-tactile bg-surface border border-white/5 rounded-2xl overflow-hidden group hover:border-teal/30">
          <div class="aspect-video bg-gradient-to-br from-green-500/20 to-surface flex items-center justify-center overflow-hidden">
            <span class="text-subtle text-sm group-hover:scale-110 transition-transform duration-500">Screenshot Preview</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs bg-teal/10 text-teal px-2.5 py-1 rounded-full">Logistics</span>
              <span class="text-xs bg-white/5 text-subtle px-2.5 py-1 rounded-full">Starter</span>
            </div>
            <h3 class="font-semibold text-lg">SwiftDrop Logistics</h3>
            <p class="text-subtle text-sm mt-2">Professional landing page with booking form and WhatsApp integration.</p>
          </div>
        </div>
      </div>
      <div class="text-center mt-10 reveal">
        <a href="/portfolio" class="inline-flex items-center text-teal font-medium hover:gap-3 transition-all gap-2">
          View All Work <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">How It Works</h2>
        <p class="mt-4 text-subtle text-lg">5 simple steps to get your business online.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 stagger-children">
        {[
          { step: "01", title: "Tell Us What You Need", desc: "DM, WhatsApp, or fill out our quick form." },
          { step: "02", title: "We Plan Your Site", desc: "Scope, content collection, and timeline." },
          { step: "03", title: "We Build It", desc: "Professional development + security check." },
          { step: "04", title: "You Review It", desc: "Staging preview and revision rounds." },
          { step: "05", title: "Launch Day", desc: "Go live + analytics + ongoing hosting." },
        ].map((item) => (
          <div class="text-center lg:text-left">
            <div class="text-teal text-4xl font-bold opacity-30">{item.step}</div>
            <h3 class="mt-3 font-semibold text-lg">{item.title}</h3>
            <p class="mt-2 text-subtle text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY PEJJI -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Why Pejji?</h2>
        <p class="mt-4 text-subtle text-lg">What makes us different.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8 stagger-children">
        <div class="card-tactile flex gap-5 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
          <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Security-Audited</h3>
            <p class="mt-2 text-subtle text-sm leading-relaxed">Every site passes our security audit before launch. Your customers' data stays safe.</p>
          </div>
        </div>
        <div class="card-tactile flex gap-5 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
          <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Custom-Built</h3>
            <p class="mt-2 text-subtle text-sm leading-relaxed">Built by developers, not drag-and-drop templates. Your site is uniquely yours.</p>
          </div>
        </div>
        <div class="card-tactile flex gap-5 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
          <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Ongoing Hosting + Analytics</h3>
            <p class="mt-2 text-subtle text-sm leading-relaxed">Monthly analytics reports so you know exactly how your site is performing.</p>
          </div>
        </div>
        <div class="card-tactile flex gap-5 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
          <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Real WhatsApp Support</h3>
            <p class="mt-2 text-subtle text-sm leading-relaxed">Real support via WhatsApp, not a chatbot. We respond within 2 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">What Our Clients Say</h2>
      </div>
      <div class="carousel-track">
        <div class="carousel-slide">
          <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 h-full">
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-orange" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-light leading-relaxed">"Pejji built our restaurant website in just 5 days. Orders went up 40% in the first month. Best investment we've made."</p>
            <div class="mt-6">
              <p class="font-semibold">Mrs. Folake Adeyemi</p>
              <p class="text-subtle text-sm">Iya Basira Kitchen, Lagos</p>
            </div>
          </div>
        </div>
        <div class="carousel-slide">
          <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 h-full">
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-orange" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-light leading-relaxed">"I was skeptical about paying for a website but Pejji made the process so easy. Now my fashion brand looks professional online."</p>
            <div class="mt-6">
              <p class="font-semibold">Chidi Okonkwo</p>
              <p class="text-subtle text-sm">Ade & Co. Fashion, Abuja</p>
            </div>
          </div>
        </div>
        <div class="carousel-slide">
          <div class="card-tactile bg-surface border border-white/5 rounded-2xl p-8 h-full">
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-orange" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-light leading-relaxed">"The Card tier was perfect for us. ₦60K and we had a professional online presence within 48 hours. No stress at all."</p>
            <div class="mt-6">
              <p class="font-semibold">Aminu Bello</p>
              <p class="text-subtle text-sm">SwiftDrop Logistics, Kano</p>
            </div>
          </div>
        </div>
      </div>
      <!-- Carousel dots (mobile) -->
      <div class="flex justify-center gap-2 mt-6 md:hidden">
        <div class="carousel-dot active"></div>
        <div class="carousel-dot"></div>
        <div class="carousel-dot"></div>
      </div>
    </div>
  </section>

  <!-- CTA FOOTER -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl sm:text-4xl font-bold">Ready to get your business online?</h2>
      <p class="mt-4 text-subtle text-lg">It takes 2 minutes to get started.</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/2348000000000?text=Hi%20Pejji!%20I'm%20interested%20in%20getting%20a%20website%20for%20my%20business." target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-green-500 text-white font-semibold rounded-lg hover:bg-green-600 hover:shadow-lg hover:shadow-green-500/20 transition-all duration-300">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 hover:shadow-lg hover:shadow-orange/20 transition-all duration-300">
          Get Started
