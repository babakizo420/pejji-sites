---
import Base from '../layouts/Base.astro';
import { WHATSAPP_URL } from '../config';
---

<Base title="Pejji | Your Business Deserves a Website That Works" description="We build fast, secure, beautiful websites for Nigerian businesses. Starting from ₦60,000.">

  <!-- HERO -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-br from-teal/10 via-dark to-dark"></div>
    <div class="absolute inset-0 hero-shimmer"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-teal/5 rounded-full blur-3xl hero-glow"></div>
    <!-- Subtle particle canvas (desktop only, saves battery on mobile) -->
    <canvas id="hero-particles" class="absolute inset-0 w-full h-full pointer-events-none z-10 hidden lg:block"></canvas>
    <!-- Floating particles -->
    <div class="particle w-2 h-2 bg-teal/30 top-[20%] left-[15%]" style="animation: float1 12s ease-in-out infinite;"></div>
    <div class="particle w-3 h-3 bg-orange/20 top-[40%] right-[20%]" style="animation: float2 15s ease-in-out infinite; animation-delay: -3s;"></div>
    <div class="particle w-1.5 h-1.5 bg-teal/40 top-[60%] left-[70%]" style="animation: float1 10s ease-in-out infinite; animation-delay: -5s;"></div>
    <div class="particle w-2.5 h-2.5 bg-teal/20 top-[30%] left-[50%]" style="animation: float2 18s ease-in-out infinite; animation-delay: -8s;"></div>
    <div class="particle w-1 h-1 bg-orange/30 top-[70%] left-[30%]" style="animation: float1 14s ease-in-out infinite; animation-delay: -2s;"></div>
    <div class="particle w-2 h-2 bg-teal/25 top-[15%] right-[35%]" style="animation: float2 11s ease-in-out infinite; animation-delay: -6s;"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="max-w-xl">
          <div class="reveal inline-flex items-center gap-2.5 px-4 py-2 bg-white/5 border border-white/10 rounded-full text-sm text-subtle backdrop-blur-sm mb-8">
            <span class="accepting-dot w-2 h-2 bg-green-400 rounded-full flex-shrink-0"></span>
            Now accepting new clients
          </div>
          <h1 class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight" style="transition-delay: 50ms;">
            Your Business Deserves a Website That <span class="text-teal">Works</span>
          </h1>
          <p class="reveal mt-6 text-lg sm:text-xl text-subtle max-w-2xl leading-relaxed" style="transition-delay: 150ms;">
            We build fast, secure, beautiful websites for Nigerian businesses. Starting from ₦60,000.
          </p>
          <div class="reveal mt-10 flex flex-col items-start sm:flex-row gap-4" style="transition-delay: 250ms;">
            <a href="#portfolio" class="inline-flex items-center justify-center px-8 py-4 border-2 border-teal text-teal font-semibold rounded-lg hover:bg-teal/10 hover:shadow-lg hover:shadow-teal/10 transition-all duration-300 text-center">
              See Our Work
            </a>
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 hover:shadow-lg hover:shadow-orange/20 transition-all duration-300 text-center">
              Get Started
            </a>
          </div>
        </div>
        <!-- Floating UI Cards (desktop only) -->
        <div class="hidden lg:block relative h-[420px] reveal-right" style="transition-delay: 300ms;">
          <!-- Browser mockup card -->
          <div class="float-card-1 absolute top-0 right-0 w-[300px] bg-surface/80 border border-white/10 rounded-2xl p-5 backdrop-blur-xl shadow-2xl shadow-black/30">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400/80"></div>
            </div>
            <div class="h-2 w-4/5 bg-teal/30 rounded mb-2.5"></div>
            <div class="h-2 w-3/5 bg-orange/20 rounded mb-2.5"></div>
            <div class="h-1.5 w-11/12 bg-white/5 rounded mb-2"></div>
            <div class="h-1.5 w-4/5 bg-white/5 rounded mb-2"></div>
            <div class="h-1.5 w-5/6 bg-white/5 rounded mb-4"></div>
            <div class="flex gap-2">
              <div class="w-1/2 h-12 rounded-lg bg-teal/15"></div>
              <div class="w-1/2 h-12 rounded-lg bg-orange/15"></div>
            </div>
          </div>
          <!-- Analytics card -->
          <div class="float-card-2 absolute top-40 left-0 w-[250px] bg-surface/80 border border-white/10 rounded-2xl p-5 backdrop-blur-xl shadow-2xl shadow-black/30">
            <div class="text-xs text-subtle mb-2">Site Performance</div>
            <div class="flex items-center gap-1.5 text-teal text-sm font-medium mb-3">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              Trending up
            </div>
            <div class="flex items-end gap-1 h-12">
              <div class="w-[14%] h-[30%] bg-teal/30 rounded-sm"></div>
              <div class="w-[14%] h-[50%] bg-teal/40 rounded-sm"></div>
              <div class="w-[14%] h-[40%] bg-teal/30 rounded-sm"></div>
              <div class="w-[14%] h-[70%] bg-teal/50 rounded-sm"></div>
              <div class="w-[14%] h-[60%] bg-teal/40 rounded-sm"></div>
              <div class="w-[14%] h-[90%] bg-teal rounded-sm"></div>
              <div class="w-[14%] h-full bg-teal rounded-sm"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM STATEMENT -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center reveal">
        <p class="text-5xl sm:text-6xl lg:text-7xl font-bold text-teal mb-4" style="line-height: 1;">95%</p>
        <p class="text-xl sm:text-2xl lg:text-3xl font-medium leading-relaxed text-light">
          of Nigerian SMEs don't have a website.<br><span class="text-teal">Your competitors already do.</span>
        </p>
        <p class="mt-6 text-subtle text-lg leading-relaxed">
          Every day without one, you're losing customers to businesses that show up online.
        </p>
      </div>
    </div>
  </section>

  <!-- TIER PREVIEW CARDS -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Pick Your Tier</h2>
        <p class="mt-4 text-subtle text-lg">Transparent pricing. No hidden fees.</p>
      </div>
      <style>
        .pricing-scroll::-webkit-scrollbar { display: none; }
        .pricing-card { min-width: 270px; max-width: 280px; flex-shrink: 0; scroll-snap-align: start; }
      </style>
      <div class="pricing-scroll" style="display: flex; gap: 20px; overflow-x: auto; overflow-y: visible; padding-bottom: 16px; padding-top: 16px; margin: 0 -16px; padding-left: 16px; padding-right: 16px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none;">
        <!-- Card Tier - Teal -->
        <div class="card-tactile card-glow bg-surface rounded-2xl p-6 sm:p-8 group relative pricing-card" style="scroll-snap-align: start; border: 1px solid rgba(10,143,143,0.2);">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#0A8F8F;border-radius:12px 12px 0 0;"></div>
          <div style="color:#0A8F8F;" class="text-sm font-semibold uppercase tracking-wider">Card</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦60K</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Digital business card. Get online in 48 hours.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦10K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color:#0A8F8F;">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
        <!-- Starter - Blue -->
        <div class="card-tactile card-glow bg-surface rounded-2xl p-6 sm:p-8 group relative pricing-card" style="scroll-snap-align: start; border: 1px solid rgba(59,130,246,0.2);">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#3B82F6;border-radius:12px 12px 0 0;"></div>
          <div style="color:#3B82F6;" class="text-sm font-semibold uppercase tracking-wider">Starter</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦150K</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Professional landing page that converts.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦15K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color:#3B82F6;">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
        <!-- Growth - Orange (Popular) -->
        <div class="card-tactile card-glow bg-surface rounded-2xl p-6 sm:p-8 group relative pricing-card" style="scroll-snap-align: start; border: 2px solid rgba(245,122,31,0.3); overflow: visible;">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#F57A1F;border-radius:12px 12px 0 0;"></div>
          <div class="absolute -top-3 right-6 text-white text-xs font-semibold px-3 py-1 rounded-full" style="z-index:10;background:#F57A1F;">Popular</div>
          <div style="color:#F57A1F;" class="text-sm font-semibold uppercase tracking-wider">Growth</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦300K</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Booking, services, and customer management.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦20K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color:#F57A1F;">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
        <!-- Pro - Emerald -->
        <div class="card-tactile card-glow bg-surface rounded-2xl p-6 sm:p-8 group relative pricing-card" style="scroll-snap-align: start; border: 1px solid rgba(16,185,129,0.2);">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#10B981;border-radius:12px 12px 0 0;"></div>
          <div style="color:#10B981;" class="text-sm font-semibold uppercase tracking-wider">Pro</div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦800K+</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Full ecommerce store with payments.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦30K/mo hosting</p>
          <a href="/services" class="mt-6 inline-flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color:#10B981;">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
        <!-- Pro Max - Purple Gradient (Premium) -->
        <style>
          @keyframes glow-badge { 0%,100% { box-shadow: 0 0 8px rgba(124,58,237,0.5), 0 0 20px rgba(124,58,237,0.2); } 50% { box-shadow: 0 0 16px rgba(124,58,237,0.7), 0 0 36px rgba(124,58,237,0.35); } }
          @keyframes shimmer { 0% { background-position: -200% center; } 100% { background-position: 200% center; } }
        </style>
        <div class="card-tactile card-glow rounded-2xl p-6 sm:p-8 group relative pricing-card" style="scroll-snap-align: start; overflow: visible; border: 2px solid rgba(124,58,237,0.4); background: linear-gradient(135deg, #1A1A24 0%, #1E1530 50%, #1A1A24 100%);">
          <div style="position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,#0A8F8F,#7C3AED,#F57A1F);border-radius:12px 12px 0 0;"></div>
          <div class="absolute -top-3 right-4" style="z-index:10;">
            <span style="display:inline-block;padding:4px 14px;border-radius:9999px;font-size:10px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:#FFFFFF;background:linear-gradient(135deg,#7C3AED,#F57A1F);animation:glow-badge 2s ease-in-out infinite;">AI-POWERED</span>
          </div>
          <div>
            <span style="color:#7C3AED;" class="text-sm font-semibold uppercase tracking-wider">Pro Max</span>
          </div>
          <div class="mt-4">
            <span class="text-3xl font-bold">₦1.5M+</span>
          </div>
          <p class="mt-3 text-subtle text-sm leading-relaxed">Everything in Pro + custom AI agent that runs your business 24/7. WhatsApp bot, booking automation, lead qualification.</p>
          <p class="mt-4 text-xs text-subtle">+ ₦150K/mo hosting & agent</p>
          <a href="/services" class="mt-6 inline-flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color:#7C3AED;">
            Learn More <span class="ml-1">→</span>
          </a>
        </div>
      </div>
      <p class="text-center mt-10 reveal">
        <a href="/quiz" class="inline-flex items-center text-teal font-medium hover:gap-3 transition-all gap-2">
          Not sure which tier? Take our free quiz <span>→</span>
        </a>
      </p>
    </div>
  </section>

  <!-- PORTFOLIO CAROUSEL -->
  <section id="portfolio" class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Our Work</h2>
        <p class="mt-4 text-subtle text-lg">Real sites for real businesses.</p>
      </div>
    </div>
    <div class="portfolio-carousel-wrap">
      <div class="portfolio-carousel">
        {[
          { name: "Kachi The Barber", tag: "Barber Shop", tier: "Card", url: "https://kachi.pejji.com", img: "/portfolio/kachi-hero.jpg", gradient: "from-yellow-500/20" },
          { name: "SwiftDrop Logistics", tag: "Logistics/Delivery", tier: "Starter", url: "https://swiftdrop-demo.pejji.com", img: "/portfolio/swiftdrop-hero.jpg", gradient: "from-green-500/20" },
          { name: "SparkleClean", tag: "Cleaning Service", tier: "Starter", url: "https://cleaning-demo.pejji.com", img: "/portfolio/cleaning-hero.jpg", gradient: "from-blue-500/20" },
          { name: "Lens & Light", tag: "Photography", tier: "Starter", url: "https://photography-demo.pejji.com", img: "/portfolio/photography-hero.jpg", gradient: "from-indigo-500/20" },
          { name: "GlowUp Beauty", tag: "Beauty/Salon", tier: "Growth", url: "https://glowup-demo.pejji.com", img: "/portfolio/glowup-hero.jpg", gradient: "from-pink-500/20" },
          { name: "Amala House", tag: "Restaurant", tier: "Growth", url: "https://restaurant-demo.pejji.com", img: "/portfolio/restaurant-hero.jpg", gradient: "from-red-500/20" },
          { name: "Prime Properties", tag: "Real Estate", tier: "Growth", url: "https://realestate-demo.pejji.com", img: "/portfolio/realestate-hero.jpg", gradient: "from-emerald-500/20" },
          { name: "Ade & Co. Fashion", tag: "Fashion/E-commerce", tier: "Pro", url: "https://ade-demo.pejji.com", img: "/portfolio/ade-hero.jpg", gradient: "from-orange/20" },
        ].map((demo) => (
          <a href={demo.url} target="_blank" rel="noopener" class="portfolio-card bg-surface border border-white/5 rounded-2xl overflow-hidden group hover:border-teal/30 block flex-shrink-0">
            <div class={`aspect-video bg-gradient-to-br ${demo.gradient} to-surface flex items-center justify-center overflow-hidden`}>
              <img src={demo.img} alt={`${demo.name} website screenshot`} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs bg-teal/10 text-teal px-2.5 py-1 rounded-full">{demo.tag}</span>
                <span class="text-xs bg-white/5 text-subtle px-2.5 py-1 rounded-full">{demo.tier}</span>
              </div>
              <h3 class="font-semibold text-base">{demo.name}</h3>
              <span class="inline-flex items-center gap-1 text-teal text-sm font-medium mt-2 group-hover:gap-2 transition-all">View Site <span>→</span></span>
            </div>
          </a>
        ))}
        <!-- View All end card -->
        <a href="/portfolio" class="portfolio-card portfolio-card-viewall bg-surface border border-white/5 rounded-2xl overflow-hidden flex-shrink-0 flex items-center justify-center hover:border-teal/30 transition-colors">
          <div class="text-center p-8">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-teal/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
            <span class="text-teal font-semibold text-lg">View All Work</span>
            <p class="text-subtle text-sm mt-2">See our full portfolio</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <style>
    .portfolio-carousel-wrap {
      overflow: hidden;
      width: 100%;
    }
    .portfolio-carousel {
      display: flex;
      gap: 1.25rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 max(1rem, calc((100vw - 80rem) / 2 + 1rem));
      padding-bottom: 1rem;
    }
    .portfolio-carousel::-webkit-scrollbar {
      display: none;
    }
    .portfolio-card {
      width: 280px;
      min-width: 280px;
      max-width: 300px;
      scroll-snap-align: start;
    }
    .portfolio-card-viewall {
      min-height: 280px;
    }
    @media (min-width: 640px) {
      .portfolio-card {
        width: 300px;
        min-width: 300px;
      }
    }
  </style>

  <!-- HOW IT WORKS (Timeline) -->
  <section class="py-16 sm:py-24 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">How It Works</h2>
        <p class="mt-4 text-subtle text-lg">5 simple steps to get your business online.</p>
      </div>
      <div class="relative max-w-3xl mx-auto">
        <!-- Gradient connecting line -->
        <div class="absolute left-[31px] top-0 bottom-0 w-0.5 hidden sm:block" style="background: linear-gradient(to bottom, #0A8F8F, #F57A1F 60%, rgba(10,143,143,0.3));"></div>
        {[
          { step: "01", title: "Tell Us What You Need", desc: "DM, WhatsApp, or fill out our quick form." },
          { step: "02", title: "We Plan Your Site", desc: "Scope, content collection, and timeline." },
          { step: "03", title: "We Build It", desc: "Professional development + security check." },
          { step: "04", title: "You Review It", desc: "Staging preview and revision rounds." },
          { step: "05", title: "Launch Day", desc: "Go live + analytics + ongoing hosting." },
        ].map((item, i) => (
          <div class="flex gap-6 sm:gap-8 mb-10 reveal-left group" style={`transition-delay: ${i * 100}ms;`}>
            <div class="flex-shrink-0 relative z-10 w-16 h-16 rounded-full bg-surface border-2 border-teal flex items-center justify-center font-bold text-teal text-lg group-hover:bg-teal group-hover:text-dark group-hover:shadow-[0_0_30px_rgba(10,143,143,0.3)] transition-all duration-300">
              {item.step}
            </div>
            <div class="flex-1 bg-surface border border-white/5 rounded-2xl p-6 group-hover:border-teal/20 transition-colors">
              <h3 class="font-semibold text-lg">{item.title}</h3>
              <p class="mt-2 text-subtle text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY PEJJI -->
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold">Why Pejji?</h2>
        <p class="mt-4 text-subtle text-lg">What makes us different.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8 stagger-children">
        <div class="card-tactile flex gap-5 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
          <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Security-Audited</h3>
            <p class="mt-2 text-subtle text-sm leading-relaxed">Every site passes our security audit before launch. Your customers' data stays safe.</p>
          </div>
        </div>
        <div class="card-tactile flex gap-5 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
          <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Custom-Built</h3>
            <p class="mt-2 text-subtle text-sm leading-relaxed">Built by developers, not drag-and-drop templates. Your site is uniquely yours.</p>
          </div>
        </div>
        <div class="card-tactile flex gap-5 p-6 bg-surface border border-white/5 rounded-2xl hover:border-teal/20">
          <div class="flex-shrink-0 w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center">
