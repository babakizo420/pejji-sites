---
import Base from '../../layouts/Base.astro';

const categoryColors: Record<string, { gradient: string; badge: string; border: string }> = {
  Pricing: {
    gradient: 'from-teal/20 to-teal/5',
    badge: 'bg-teal/15 text-teal',
    border: 'hover:border-teal/40',
  },
  Compliance: {
    gradient: 'from-orange/20 to-orange/5',
    badge: 'bg-orange/15 text-orange',
    border: 'hover:border-orange/40',
  },
  Business: {
    gradient: 'from-purple-500/20 to-purple-500/5',
    badge: 'bg-purple-500/15 text-purple-400',
    border: 'hover:border-purple-400/40',
  },
};

const posts = [
  {
    title: "How Much Does a Website Cost in Nigeria in 2026?",
    slug: "how-much-does-website-cost-nigeria",
    excerpt: "A transparent breakdown of website pricing in Nigeria - from DIY builders to full agencies - and where Pejji fits in.",
    date: "2026-04-06",
    category: "Pricing",
    readingTime: "6 min read"
  },
  {
    title: "NDPA Compliance for Nigerian Businesses: What You Need in 2026",
    slug: "ndpa-compliance-nigerian-businesses",
    excerpt: "The Nigeria Data Protection Act (NDPA) 2023 is being enforced. Here is what your business needs to stay compliant and avoid fines.",
    date: "2026-04-04",
    category: "Compliance",
    readingTime: "7 min read"
  },
  {
    title: "Why Your Nigerian Business Needs a Website in 2026",
    slug: "why-nigerian-business-needs-website",
    excerpt: "39.4 million MSMEs in Nigeria operate without a website. Here is why that is costing them customers and credibility.",
    date: "2026-04-02",
    category: "Business",
    readingTime: "5 min read"
  }
];

const featured = posts[0];
const rest = posts.slice(1);
---

<Base title="Blog | Pejji" description="Insights on web design, NDPA compliance, and growing your Nigerian business online. Expert guides from the Pejji team.">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-teal/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-12 sm:pb-16 relative">
      <div class="text-center">
        <span class="inline-block px-4 py-1.5 bg-teal/10 text-teal text-sm font-semibold rounded-full mb-6 tracking-wide uppercase">Blog</span>
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl tracking-tight mb-6">Insights for Nigerian Businesses</h1>
        <p class="text-subtle text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">Web design, security, and NDPA compliance - practical guides to help your business grow online.</p>
        <div class="mt-8 w-24 h-1 bg-gradient-to-r from-teal to-teal/30 rounded-full mx-auto"></div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 sm:pb-28">
    <!-- Featured post -->
    <a href={`/blog/${featured.slug}`} class={`group block mb-12 bg-surface border border-white/10 rounded-2xl overflow-hidden ${categoryColors[featured.category].border} transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-teal/5`}>
      <div class={`bg-gradient-to-br ${categoryColors[featured.category].gradient} px-8 py-6 sm:py-8 flex items-center gap-3`}>
        <span class="px-3 py-1 bg-white/10 text-xs font-bold rounded-full uppercase tracking-wider text-light/80">Featured</span>
        <span class={`px-3 py-1 ${categoryColors[featured.category].badge} text-xs font-semibold rounded-full`}>{featured.category}</span>
      </div>
      <div class="p-8 sm:p-10">
        <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl leading-snug mb-4 group-hover:text-teal transition-colors duration-300">{featured.title}</h2>
        <p class="text-subtle text-base sm:text-lg leading-relaxed mb-6 max-w-3xl">{featured.excerpt}</p>
        <div class="flex flex-wrap items-center gap-4 sm:gap-6">
          <time class="text-subtle text-sm">{new Date(featured.date).toLocaleDateString('en-NG', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <span class="text-subtle text-sm">{featured.readingTime}</span>
          <span class="ml-auto text-teal text-sm font-semibold group-hover:translate-x-1 transition-transform duration-300 inline-flex items-center gap-1.5">
            Read article
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </div>
      </div>
    </a>

    <!-- Remaining posts -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {rest.map((post) => {
        const colors = categoryColors[post.category];
        return (
          <a href={`/blog/${post.slug}`} class={`group block bg-surface border border-white/10 rounded-2xl overflow-hidden ${colors.border} transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/10`}>
            {/* Gradient header */}
            <div class={`bg-gradient-to-br ${colors.gradient} px-6 py-5`}>
              <span class={`inline-block px-3 py-1 ${colors.badge} text-xs font-semibold rounded-full`}>{post.category}</span>
            </div>
            {/* Content */}
            <div class="p-6 sm:p-8">
              <h2 class="font-serif text-xl sm:text-2xl leading-snug mb-3 group-hover:text-teal transition-colors duration-300">{post.title}</h2>
              <p class="text-subtle text-sm sm:text-base leading-relaxed mb-5">{post.excerpt}</p>
              <div class="flex items-center justify-between pt-4 border-t border-white/5">
                <div class="flex items-center gap-4">
                  <time class="text-subtle text-xs">{new Date(post.date).toLocaleDateString('en-NG', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                  <span class="text-subtle text-xs">{post.readingTime}</span>
                </div>
                <span class="text-teal text-sm font-medium group-hover:translate-x-1 transition-transform duration-300 inline-flex items-center gap-1">
                  Read
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Base>
