---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
  category?: string;
  readingTime?: string;
  ogImage?: string;
}

const {
  title,
  description,
  date,
  author = "Pejji Team",
  category = "Business",
  readingTime = "5 min read",
  ogImage = "https://pejji.com/og-image.png"
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-NG', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const categoryColors: Record<string, { gradient: string; badge: string; accent: string }> = {
  Pricing: {
    gradient: 'from-teal/20 via-teal/5 to-transparent',
    badge: 'bg-teal/15 text-teal',
    accent: '#0A8F8F',
  },
  Compliance: {
    gradient: 'from-orange/20 via-orange/5 to-transparent',
    badge: 'bg-orange/15 text-orange',
    accent: '#F57A1F',
  },
  Business: {
    gradient: 'from-purple-500/20 via-purple-500/5 to-transparent',
    badge: 'bg-purple-500/15 text-purple-400',
    accent: '#a855f7',
  },
};

const colors = categoryColors[category!] || categoryColors.Business;

const allPosts = [
  {
    title: "How Much Does a Website Cost in Nigeria in 2026?",
    slug: "how-much-does-website-cost-nigeria",
    excerpt: "A transparent breakdown of website pricing in Nigeria - from DIY builders to full agencies.",
    date: "2026-04-06",
    category: "Pricing",
    readingTime: "6 min read"
  },
  {
    title: "NDPA Compliance for Nigerian Businesses: What You Need in 2026",
    slug: "ndpa-compliance-nigerian-businesses",
    excerpt: "The NDPA 2023 is being enforced. Here is what your business needs to stay compliant.",
    date: "2026-04-04",
    category: "Compliance",
    readingTime: "7 min read"
  },
  {
    title: "Why Your Nigerian Business Needs a Website in 2026",
    slug: "why-nigerian-business-needs-website",
    excerpt: "39.4 million MSMEs operate without a website. Here is why that is costing them.",
    date: "2026-04-02",
    category: "Business",
    readingTime: "5 min read"
  }
];

const currentSlug = Astro.url.pathname.replace('/blog/', '').replace(/\/$/, '');
const morePosts = allPosts.filter(p => p.slug !== currentSlug).slice(0, 2);

const morePostColors: Record<string, { badge: string }> = {
  Pricing: { badge: 'bg-teal/15 text-teal' },
  Compliance: { badge: 'bg-orange/15 text-orange' },
  Business: { badge: 'bg-purple-500/15 text-purple-400' },
};
---

<Base title={`${title} | Pejji Blog`} description={description}>
  <!-- Blog Article structured data -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "image": ogImage,
    "author": {
      "@type": "Organization",
      "name": "Pejji",
      "url": "https://pejji.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Pejji",
      "logo": {
        "@type": "ImageObject",
        "url": "https://pejji.com/favicon.svg"
      }
    },
    "datePublished": date,
    "dateModified": date,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://pejji.com${Astro.url.pathname}`
    }
  })} />

  <!-- Hero header -->
  <div class={`relative overflow-hidden bg-gradient-to-b ${colors.gradient}`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-12 sm:pt-20 pb-10 sm:pb-14">
      <!-- Back to blog -->
      <a href="/blog" class="inline-flex items-center gap-2 text-subtle hover:text-teal text-sm transition-colors mb-8 group">
        <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Blog
      </a>

      <!-- Category badge -->
      <span class={`inline-block px-4 py-1.5 ${colors.badge} text-xs font-bold rounded-full mb-5 uppercase tracking-wider`}>{category}</span>

      <!-- Title -->
      <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl leading-tight tracking-tight mb-8">{title}</h1>

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-5 text-subtle text-sm">
        <span class="flex items-center gap-2">
          <span class="w-7 h-7 rounded-full bg-teal/20 flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </span>
          {author}
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          {formattedDate}
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {readingTime}
        </span>
      </div>

      <!-- Accent line -->
      <div class="mt-10 h-0.5 rounded-full" style={`background: linear-gradient(to right, ${colors.accent}, transparent);`}></div>
    </div>
  </div>

  <!-- Article body -->
  <article class="max-w-[720px] mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="blog-content">
      <slot />
    </div>

    <!-- Share section -->
    <div class="mt-16 pt-8 border-t border-white/10">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <span class="text-subtle text-sm font-medium uppercase tracking-wider">Share this article</span>
        <div class="flex items-center gap-3">
          <button
            id="copy-link-btn"
            class="inline-flex items-center gap-2 px-4 py-2 bg-surface border border-white/10 rounded-lg text-sm text-subtle hover:text-teal hover:border-teal/30 transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            <span id="copy-link-text">Copy link</span>
          </button>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://pejji.com/blog/${currentSlug}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-surface border border-white/10 rounded-lg text-sm text-subtle hover:text-teal hover:border-teal/30 transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Post
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://pejji.com/blog/${currentSlug}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-surface border border-white/10 rounded-lg text-sm text-subtle hover:text-teal hover:border-teal/30 transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Share
          </a>
        </div>
      </div>
    </div>

    <!-- CTA banner -->
    <div class="mt-12 relative overflow-hidden rounded-2xl">
      <div class="absolute inset-0 bg-gradient-to-br from-teal/15 via-surface to-surface"></div>
      <div class="relative p-8 sm:p-10 border border-teal/20 rounded-2xl text-center">
        <span class="inline-block px-3 py-1 bg-teal/10 text-teal text-xs font-semibold rounded-full mb-4 uppercase tracking-wider">Get started</span>
        <h3 class="font-serif text-2xl sm:text-3xl mb-4">Ready to get your business online?</h3>
        <p class="text-subtle text-base sm:text-lg mb-8 max-w-lg mx-auto leading-relaxed">Pejji builds fast, secure, NDPA-compliant websites for Nigerian businesses - starting from &#8358;60,000.</p>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 bg-orange text-white font-semibold rounded-lg hover:bg-orange/90 hover:shadow-lg hover:shadow-orange/20 hover:-translate-y-0.5 transition-all duration-300">
          Get Started Today
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </article>

  <!-- More articles -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20 sm:pb-28">
    <div class="border-t border-white/10 pt-12 sm:pt-16">
      <h2 class="font-serif text-2xl sm:text-3xl mb-8 text-center">More articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {morePosts.map((post) => {
          const postColors = morePostColors[post.category] || morePostColors.Business;
          return (
            <a href={`/blog/${post.slug}`} class="group block bg-surface border border-white/10 rounded-2xl overflow-hidden hover:border-teal/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/10">
              <div class="p-6 sm:p-8">
                <span class={`inline-block px-3 py-1 ${postColors.badge} text-xs font-semibold rounded-full mb-4`}>{post.category}</span>
                <h3 class="font-serif text-lg sm:text-xl leading-snug mb-3 group-hover:text-teal transition-colors duration-300">{post.title}</h3>
                <p class="text-subtle text-sm leading-relaxed mb-4">{post.excerpt}</p>
                <div class="flex items-center justify-between pt-4 border-t border-white/5">
                  <div class="flex items-center gap-3">
                    <time class="text-subtle text-xs">{new Date(post.date).toLocaleDateString('en-NG', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                    <span class="text-subtle text-xs">{post.readingTime}</span>
                  </div>
                  <span class="text-teal text-sm font-medium group-hover:translate-x-1 transition-transform duration-300 inline-flex items-center gap-1">
                    Read
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <style>
    /* Blog body typography */
    .blog-content {
      font-size: 1.125rem;
      line-height: 1.8;
    }
    .blog-content h2 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 1.875rem;
      font-weight: 400;
      margin-top: 3rem;
      margin-bottom: 1.25rem;
      line-height: 1.3;
      padding-left: 1rem;
      border-left: 3px solid #0A8F8F;
      color: rgb(var(--color-light));
    }
    .blog-content h3 {
      font-size: 1.375rem;
      font-weight: 700;
      margin-top: 2.25rem;
      margin-bottom: 0.75rem;
      line-height: 1.4;
      color: rgb(var(--color-light));
      letter-spacing: -0.01em;
    }
    .blog-content h4 {
      font-size: 1.125rem;
      font-weight: 700;
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
      line-height: 1.4;
      color: #0bbdbd;
    }
    .blog-content p {
      color: rgb(var(--color-subtle));
      line-height: 1.85;
      margin-bottom: 1.5rem;
    }
    .blog-content ul, .blog-content ol {
      color: rgb(var(--color-subtle));
      line-height: 1.85;
      margin-bottom: 1.5rem;
      padding-left: 0;
      list-style: none;
    }
    .blog-content ul li {
      position: relative;
      padding-left: 1.5rem;
      margin-bottom: 0.625rem;
    }
    .blog-content ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.65em;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #0A8F8F;
    }
    .blog-content ol {
      counter-reset: blog-counter;
    }
    .blog-content ol li {
      position: relative;
      padding-left: 2rem;
      margin-bottom: 0.625rem;
      counter-increment: blog-counter;
    }
    .blog-content ol li::before {
      content: counter(blog-counter) '.';
      position: absolute;
      left: 0;
      font-weight: 600;
      color: #0A8F8F;
    }
    .blog-content strong {
      color: rgb(var(--color-light));
      font-weight: 600;
    }
    .blog-content a {
      color: #0A8F8F;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: rgba(10, 143, 143, 0.3);
      transition: text-decoration-color 0.2s;
    }
    .blog-content a:hover {
      color: #0bbdbd;
      text-decoration-color: #0bbdbd;
    }
    .blog-content blockquote {
      border-left: 3px solid #0A8F8F;
      padding: 1rem 1.5rem;
      margin: 2rem 0;
      background: rgba(10, 143, 143, 0.05);
      border-radius: 0 0.75rem 0.75rem 0;
      color: rgb(var(--color-subtle));
      font-style: italic;
    }
    .blog-content table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      margin: 2rem 0;
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .blog-content th, .blog-content td {
      padding: 0.875rem 1.25rem;
      text-align: left;
      color: rgb(var(--color-subtle));
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .blog-content th {
      background: rgba(10, 143, 143, 0.08);
      color: rgb(var(--color-light));
      font-weight: 600;
      font-size: 0.875rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .blog-content tr:last-child td {
      border-bottom: none;
    }
    .blog-content tr:hover td {
      background: rgba(255, 255, 255, 0.02);
    }
    .blog-content code {
      background: rgba(255, 255, 255, 0.06);
      padding: 0.15em 0.4em;
      border-radius: 0.375rem;
      font-size: 0.9em;
      color: #0bbdbd;
    }
    .blog-content pre {
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 0.75rem;
      padding: 1.25rem 1.5rem;
      overflow-x: auto;
      margin: 2rem 0;
    }
    .blog-content pre code {
      background: none;
      padding: 0;
      border-radius: 0;
    }

    /* Light mode overrides */
    html.light .blog-content table {
      border-color: rgba(0, 0, 0, 0.1);
    }
    html.light .blog-content th, html.light .blog-content td {
      border-color: rgba(0, 0, 0, 0.06);
    }
    html.light .blog-content th {
      background: rgba(10, 143, 143, 0.06);
    }
    html.light .blog-content tr:hover td {
      background: rgba(0, 0, 0, 0.02);
    }
    html.light .blog-content blockquote {
      background: rgba(10, 143, 143, 0.04);
    }
    html.light .blog-content code {
      background: rgba(0, 0, 0, 0.05);
    }
    html.light .blog-content pre {
      background: rgba(0, 0, 0, 0.04);
      border-color: rgba(0, 0, 0, 0.08);
    }
  </style>

  <script>
    const btn = document.getElementById('copy-link-btn');
    const text = document.getElementById('copy-link-text');
    if (btn && text) {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          text.textContent = 'Copied!';
          btn.classList.add('border-teal/40', 'text-teal');
          setTimeout(() => {
            text.textContent = 'Copy link';
            btn.classList.remove('border-teal/40', 'text-teal');
          }, 2000);
        } catch {
          text.textContent = 'Failed';
          setTimeout(() => { text.textContent = 'Copy link'; }, 2000);
        }
      });
    }
  </script>
</Base>
